{
  "name": "pleco-codec",
  "version": "0.1.0",
  "description": "CODEC v2 core: membership programs on client-owned rails. Billing adapters (Square now, Stripe stub), Resend comms, and processor-blind site components. One-time build, no platform cut, Pleco never in the money path.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./billing": {
      "types": "./dist/billing/index.d.ts",
      "default": "./dist/billing/index.js"
    },
    "./comms": {
      "types": "./dist/comms/index.d.ts",
      "default": "./dist/comms/index.js"
    },
    "./site": {
      "types": "./dist/site/index.d.ts",
      "default": "./dist/site/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "CODEC-v2-CORE.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "pretest": "npm run build && tsc -p tsconfig.test.json",
    "test": "node --test \".test-build/test/*.test.js\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.0",
    "typescript": "^5.7.0"
  }
}
