# CODEC club-host — environment.
# Copy to .env for local dev; set these in the deploy environment per client.
# Secrets live here ONLY; non-secret wiring (venue name, audience id, addresses)
# lives in the instance config (src/instances/*.ts).

# Which client this deploy serves: outer-heaven | sunset
CODEC_INSTANCE=outer-heaven

# Owner dashboard passcode (shared, one per deploy). Rotate to sign everyone out.
OWNER_PASSCODE=

# --- Square (processor: square) ---
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_WEBHOOK_SIGNATURE_KEY=
# Must EXACTLY match the notification URL configured on the Square webhook
# subscription (Square signs notificationUrl + body).
SQUARE_WEBHOOK_NOTIFICATION_URL=https://your-club.example/api/webhooks/billing
SQUARE_ENV=sandbox            # sandbox | production
SQUARE_REDIRECT_URL=          # optional thank-you page after checkout
SQUARE_MANAGE_URL=            # optional "manage your membership" page (Square buyer-account explainer)
# tierId=planVariationId pairs, comma-separated, after createPlan:
#   SQUARE_TIER_REFS=beans-2=VAR_ABC,beans-4=VAR_DEF
SQUARE_TIER_REFS=

# --- Resend (comms) ---
RESEND_API_KEY=

# --- Stripe (processor: stripe — Living Room; adapter still a stub) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SIGNING_SECRET=
STRIPE_PORTAL_RETURN_URL=
