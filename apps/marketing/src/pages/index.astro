---
import '../styles/global.css';
// Real brand assets from the Pleco kit (koda-wzkp/pleco-site). We inline their
// inner markup into reusable <symbol>s so the same mask/mark renders once and is
// referenced via <use> — matching pleco.dev's header exactly (FIX 1).
import pmarkRaw from '../assets/brand/logo-teal-square.svg?raw';
import fishRaw from '../assets/brand/pleco-fish.svg?raw';

const inner = (svg: string) => svg.replace(/^[\s\S]*?<svg[^>]*>/, '').replace(/<\/svg>\s*$/, '');
const pmarkInner = inner(pmarkRaw);
// Strip the hardcoded fill so the fish inherits its color from CSS (teal in the
// hero, cream in the footer).
const fishInner = inner(fishRaw).replace(/\s*fill="[^"]*"/, '');

const REPO_URL = 'https://github.com/koda-wzkp/Pleco-Codec';
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<!-- FIX 2: tell browsers/webviews this page is light-only; never auto-invert -->
<meta name="color-scheme" content="light" />
<meta name="theme-color" content="#FAF6EE" />
<title>CODEC — Own your membership program</title>
<meta name="description" content="CODEC builds membership and club programs that run on your own Square or Stripe. One-time build, open source, you own the code and the member list. No platform taking a cut of every member." />
<link rel="canonical" href="https://codec.pleco.dev/" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta property="og:title" content="CODEC — Own your membership program" />
<meta property="og:description" content="Membership and club programs on your own payment rails. One-time build. No platform cut, ever." />
<meta property="og:type" content="website" />
<meta property="og:url" content="https://codec.pleco.dev/" />
<meta property="og:image" content="https://codec.pleco.dev/og.png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta name="twitter:card" content="summary_large_image" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<!-- IBM Plex family, matching pleco.dev (Serif = display, Sans = body, Mono = eyebrows/terminal) -->
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Serif:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
<script is:inline>
  // FIX 2: reveal animation only arms when JS is actually running, the browser
  // supports IntersectionObserver, and the user hasn't asked for reduced motion.
  // Without this class, .reveal content stays fully visible.
  if ('IntersectionObserver' in window &&
      !(window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches)) {
    document.documentElement.classList.add('js');
  }
</script>
</head>
<body>

<!-- Brand symbols (real assets), defined once and referenced via <use>. -->
<svg width="0" height="0" style="position:absolute" aria-hidden="true" focusable="false">
  <symbol id="pmark" viewBox="0 0 120 120"><Fragment set:html={pmarkInner} /></symbol>
  <symbol id="fish" viewBox="0 0 1000 511"><Fragment set:html={fishInner} /></symbol>
</svg>

<nav>
  <div class="wrap nav-in">
    <a class="brand" href="#top"><svg aria-hidden="true"><use href="#pmark" /></svg><span class="wm"><span class="wm-pleco">Pleco</span> <span class="wm-codec">CODEC</span></span></a>
    <span class="nav-sp"></span>
    <div class="nav-links">
      <a href="#how">How it works</a>
      <a href="#open-source">Open source</a>
      <a href="#packages">Packages</a>
      <a class="repo-btn" href={REPO_URL}>
        <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
        Repo
      </a>
    </div>
  </div>
</nav>

<main id="top">

  <!-- HERO -->
  <header class="hero">
    <div class="hero-fish"><svg aria-hidden="true"><use href="#fish" /></svg></div>
    <div class="wrap">
      <h1>Your club. Your rails. <span class="teal">Your&nbsp;code.</span></h1>
      <p class="lede">CODEC builds membership and club programs that run on the payment account you already own. One-time build, open source, no platform skimming every member — forever.</p>
      <div class="hero-cta">
        <a class="btn btn-primary" href="#packages">See what a build includes</a>
        <a class="btn btn-ghost" href="#open-source">Read the source</a>
      </div>
    </div>
  </header>

  <!-- PLATFORM TAX -->
  <section class="tax">
    <div class="wrap">
      <p class="eyebrow">The platform tax</p>
      <div class="cols">
        <div>
          <h2>A subscription platform takes a cut of every member. Every month. Forever.</h2>
          <p>Platforms like Table22 charge around <b>10% of top-line plus processing</b>. Your members sign up on the platform's domain, live on its list, and route support through it. Leave, and the club can't come with you cleanly.</p>
          <p>CODEC is the other model: the club runs on <b>your</b> Square or Stripe, signup lives on <b>your</b> site, and the code sits in a repo with <b>your</b> name on it.</p>
        </div>
        <div class="taxfig" aria-label="Annual comparison for a 60-member club">
          <div class="row"><span>Club revenue / yr</span><span class="v">$43,200</span></div>
          <div class="row bad"><span>Platform fee (~10%)</span><span class="v">– $4,320</span></div>
          <div class="row good"><span>On CODEC</span><span class="v">$0</span></div>
          <p class="cap">Illustrative: 60 members × $60/mo. Card processing (~2.9%) applies either way, since platforms charge 10% on top of it. Real figures come from your dashboard.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section id="how">
    <div class="wrap">
      <p class="eyebrow reveal">How it works</p>
      <h2 class="sec-title reveal">Everything lives in an account you own.</h2>
      <p class="sec-sub reveal">CODEC isn't a platform you log into. It's a standard web app wired to the services you already trust — nothing runs through us.</p>
      <div class="own-grid">
        <div class="own-card reveal"><div class="k">Billing</div><h3>Your processor</h3><p>Recurring charges run on your own Square or Stripe. Checkout happens on their hosted pages, so no card data ever touches the site and there's no PCI burden.</p></div>
        <div class="own-card reveal"><div class="k">Signup</div><h3>Your domain</h3><p>Members join on your own site and manage their own pauses, cancellations, and card updates. No app link to a platform you don't control.</p></div>
        <div class="own-card reveal"><div class="k">Ownership</div><h3>Your code</h3><p>The build lives in a GitHub repo in your account, licensed so anyone can maintain it. Hand it to any developer — no permission from us required.</p></div>
      </div>
    </div>
  </section>

  <!-- OPEN SOURCE -->
  <section class="oss" id="open-source">
    <div class="wrap">
      <p class="eyebrow reveal">Open source</p>
      <h2 class="reveal">The engine is public. So "you own it" isn't a promise — it's a license.</h2>
      <p class="osslede reveal">CODEC's core is released under Apache-2.0. Read it, fork it, deploy it yourself, or hire anyone to. The value we sell is the program design and the build — not lock-in.</p>
      <div class="term reveal">
        <div class="term-bar"><span class="dot r"></span><span class="dot y"></span><span class="dot g"></span><span class="fn">pleco-codec</span></div>
<pre><span class="p">$</span> <span class="k">git clone</span> <span class="s">{REPO_URL}</span>
<span class="c"># Square adapter, Stripe adapter, member events, comms.</span>
<span class="c"># Your keys, your accounts, your data.</span>

<span class="p">$</span> <span class="k">cat</span> LICENSE
<span class="c">Apache License, Version 2.0 — Copyright 2026 Pleco LLC</span>
<span class="c"># You may use, modify, and deploy this. Nobody can</span>
<span class="c"># take it back, reprice it, or shut it off from you.</span></pre>
      </div>
      <p class="oss-note">Not a developer? That's what the build is for. The open license just means you're never trapped — the thing you paid for can be maintained by anyone, forever. <a href={REPO_URL}>See the repo →</a></p>
    </div>
  </section>

  <!-- PACKAGES -->
  <section id="packages">
    <div class="wrap">
      <p class="eyebrow reveal">What a build includes</p>
      <h2 class="sec-title reveal">One-time build. You keep everything.</h2>
      <p class="sec-sub reveal">Priced by scope, not by member count. No rev-share, no per-member fees — ever.</p>
      <div class="pk-grid">
        <div class="pk reveal">
          <div class="name">Club Launch</div>
          <div class="price">$2,500–3,500</div>
          <div class="unit">one-time</div>
          <ul>
            <li>Program design workshop</li>
            <li>Billing + signup page on your rails</li>
            <li>Launch campaign to your list</li>
            <li>30 days of adjustments</li>
          </ul>
        </div>
        <div class="pk feature reveal">
          <div class="name">Club + Portal</div>
          <div class="price">$5,000–6,500</div>
          <div class="unit">one-time</div>
          <ul>
            <li>Everything in Launch</li>
            <li>Member login</li>
            <li>Self-serve subscription management</li>
            <li>Member perks display</li>
          </ul>
        </div>
        <div class="pk reveal">
          <div class="name">Full Stack</div>
          <div class="price">$8,000–12,000</div>
          <div class="unit">one-time</div>
          <ul>
            <li>Everything in Portal</li>
            <li>Full custom website</li>
            <li>A CMS you can edit yourself</li>
            <li>Fast, modern, yours</li>
          </ul>
        </div>
      </div>
      <p class="pk-foot">Optional care plan: <b>$100–200/mo</b> — monitoring, updates, small changes. Cancel anytime; everything keeps working.</p>
    </div>
  </section>

  <!-- LIVE NOW -->
  <section class="live">
    <div class="wrap">
      <p class="eyebrow reveal">Live now</p>
      <h2 class="sec-title reveal">Running in the wild.</h2>
      <div class="live-grid">
        <div class="live-card reveal">
          <span class="tag">Wine club</span>
          <h3>The Sunset Wine Club</h3>
          <div class="loc">Sunset Wine and Tapas · Carrabelle, FL</div>
          <p>A pickup-only wine club with a founding-member waitlist, billing that starts only when the first pickup is ready — on the venue's own Square.</p>
        </div>
        <div class="live-card reveal">
          <span class="tag">Bean club</span>
          <h3>The Outer Heaven Bean Club</h3>
          <div class="loc">Outer Heaven Espresso · Nevada City, CA</div>
          <p>A monthly coffee subscription with pickup timed to the roast, so members take home beans at their peak — on the roaster's own Square.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <div class="wrap">
      <h2 class="reveal">Stop renting your regulars.</h2>
      <p class="reveal">Tell me about your shop and the kind of club you'd want. I'll tell you what it takes to own it.</p>
      <div class="hero-cta reveal">
        <a class="btn btn-primary" href="mailto:hello@pleco.dev?subject=CODEC%20for%20my%20shop">Start a conversation</a>
        <a class="btn btn-ghost" href={REPO_URL}>Browse the source</a>
      </div>
    </div>
  </section>
</main>

<footer>
  <div class="foot-fish"><svg aria-hidden="true"><use href="#fish" /></svg></div>
  <div class="wrap foot-in">
    <a class="brand" href="#top"><svg aria-hidden="true"><use href="#pmark" /></svg><span class="wm"><span class="wm-pleco">Pleco</span> <span class="wm-codec">CODEC</span></span></a>
    <span class="foot-sp"></span>
    <a href="https://pleco.dev">pleco.dev</a>
    <a href="mailto:hello@pleco.dev">hello@pleco.dev</a>
    <a href={REPO_URL}>GitHub</a>
  </div>
</footer>

<script is:inline>
  (function(){
    if (!document.documentElement.classList.contains('js')) return;
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); } });
    }, {threshold:0.12, rootMargin:'0px 0px -40px 0px'});
    document.querySelectorAll('.reveal').forEach(function(el){ io.observe(el); });
  })();
</script>
</body>
</html>
